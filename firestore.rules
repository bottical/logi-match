rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function systemUserDoc() { return /databases/$(database)/documents/systemUsers/$(request.auth.uid); }
    function isSystemOwner() {
      return signedIn() && exists(systemUserDoc()) && get(systemUserDoc()).data.isActive == true && get(systemUserDoc()).data.role == 'systemOwner';
    }
    function userTenantDoc() { return /databases/$(database)/documents/userTenants/$(request.auth.uid); }
    function belongsToClient(clientId) {
      return signedIn()
        && exists(userTenantDoc())
        && get(userTenantDoc()).data.active == true
        && get(userTenantDoc()).data.clientId == clientId
        && exists(/databases/$(database)/documents/clients/$(clientId)/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/clients/$(clientId)/users/$(request.auth.uid)).data.isActive == true;
    }
    function clientRole(clientId) { return get(/databases/$(database)/documents/clients/$(clientId)/users/$(request.auth.uid)).data.role; }
    function isClientAdmin(clientId) { return belongsToClient(clientId) && clientRole(clientId) == 'admin'; }
    function isClientWorker(clientId) { return belongsToClient(clientId) && clientRole(clientId) == 'worker'; }

    match /systemUsers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update: if isSystemOwner();
      allow delete: if false;
    }

    match /userTenants/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update: if isSystemOwner();
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if belongsToClient(clientId) || isSystemOwner();
      allow create, update: if isSystemOwner();
      allow delete: if false;

      match /users/{uid} {
        allow read: if belongsToClient(clientId) || isSystemOwner();
        allow create, update: if isSystemOwner();
        allow delete: if false;
      }
      match /workers/{workerId} {
        allow read: if belongsToClient(clientId) || isSystemOwner();
        allow create, update: if isSystemOwner();
        allow delete: if false;
      }
      match /csvMapping/{docId} {
        allow read: if belongsToClient(clientId);
        allow create, update: if isClientAdmin(clientId);
        allow delete: if false;
      }
      match /importBatches/{batchId} {
        allow read: if belongsToClient(clientId);
        allow create, update: if isClientAdmin(clientId);
        allow delete: if false;
      }
      match /inspectionWorks/{workId} {
        allow read: if belongsToClient(clientId);
        allow create: if isClientAdmin(clientId);
        allow update: if isClientAdmin(clientId) || isClientWorker(clientId);
        allow delete: if false;
        match /items/{itemId} {
          allow read: if belongsToClient(clientId);
          allow create: if isClientAdmin(clientId);
          allow update: if isClientAdmin(clientId) || isClientWorker(clientId);
          allow delete: if false;
        }
      }
      match /scanLogs/{logId} {
        allow read: if isClientAdmin(clientId);
        allow create: if belongsToClient(clientId);
        allow update, delete: if false;
      }
      match /operationLogs/{logId} {
        allow read: if isClientAdmin(clientId) || isSystemOwner();
        allow create: if belongsToClient(clientId) || isSystemOwner();
        allow update, delete: if false;
      }
    }
  }
}
